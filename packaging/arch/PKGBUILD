# Maintainer: Nick Telford <nick.telford@gmail.com>
pkgname=aws-vpn-systemd
pkgver=@VERSION@
pkgrel=1
pkgdesc="SystemD services for managing AWS Client VPN without the GUI, including a patched OpenVPN."
arch=('x86_64')
url="https://github.com/nicktelford/aws-vpn-systemd"
license=('GPL-2.0-only')
depends=('systemd' 'polkit' 'openssl' 'socat')
makedepends=('autoconf' 'automake' 'libtool' 'pkg-config')
options=('!debug')
sha256sums=('18db05f3d5eee3663db1914590044e5f96ff5cd47b6e7846c6a350806c23dbce'
            '4e426ab2e74391b1c85f81f80b15fc456e4190d9febcbf884a58fca19a135b87')
source=('https://build.openvpn.net/downloads/releases/openvpn-@OPENVPN_VER@.tar.gz'
        'openvpn-@OPENVPN_VER@-aws.patch')
validpgpkeys=()

prepare() {
  cd "$srcdir/openvpn-@OPENVPN_VER@"
  patch -p1 < "$srcdir/openvpn-@OPENVPN_VER@-aws.patch"
  autoreconf -fi
}

build() {
  cd "$srcdir/openvpn-@OPENVPN_VER@"
  ./configure \
    --disable-lzo \
    --disable-lz4 \
    --disable-plugins \
    --disable-pkcs11 \
    --disable-systemd \
    --with-crypto-library=openssl
  make
}

package() {
  local _src="$startdir/../../src"
  install -Dm755 "$srcdir/openvpn-@OPENVPN_VER@/src/openvpn/openvpn" "$pkgdir/usr/bin/acvc-openvpn"
  install -Dm755 "$_src/aws-vpn" "$pkgdir/usr/bin/aws-vpn"
  install -Dm755 "$_src/dns-up" "$pkgdir/usr/lib/aws-vpn-systemd/dns-up"
  install -Dm755 "$_src/dns-down" "$pkgdir/usr/lib/aws-vpn-systemd/dns-down"
  install -Dm644 "$_src/00-openvpn-resolved.rules" "$pkgdir/usr/share/polkit-1/rules.d/00-openvpn-resolved.rules"
  install -Dm644 "$_src/system_aws-vpn@.service" "$pkgdir/usr/lib/systemd/system/aws-vpn@.service"
  install -Dm644 "$_src/user_aws-vpn@.service" "$pkgdir/usr/lib/systemd/user/aws-vpn@.service"
  install -Dm644 "$_src/connected.html" "$pkgdir/usr/share/aws-vpn-systemd/connected.html"
  install -Dm644 "$_src/aws-vpn-systemd.sysusers" "$pkgdir/usr/lib/sysusers.d/aws-vpn-systemd.conf"
  install -dm755 "$pkgdir/etc/openvpn/client"
}

#!/usr/bin/env bash
BROWSER_CMD=$(command -v xdg-open 2>/dev/null || printf '%s' "${BROWSER-}")
VPN_CMD="/usr/bin/acvc-openvpn"

SAML_RESPONSE_TIMEOUT=${SAML_RESPONSE_TIMEOUT:-300}

HTML_BODY="/usr/share/aws-vpn-systemd/connected.html"
if [ ! -f "$HTML_BODY" ]; then
  HTML_BODY="$(dirname "$(readlink -f "$0")")/connected.html"
fi
if [ ! -f "$HTML_BODY" ]; then
  echo "ERROR: Cannot find connected.html (looked in /usr/share/aws-vpn-systemd/ and next to aws-vpn script)." >&2
  exit 1
fi


VPN_INSTANCE="$1"
VPN_CONF="/etc/openvpn/client/$VPN_INSTANCE.conf"

wait_for_unlock() {
  local session active locked
  session=$(loginctl show-user "$USER" --property=Display --value 2>/dev/null)
  [ -z "$session" ] && return 0

  systemd-notify "STATUS=Waiting for user session to unlock..."
  while :; do
    active=$(loginctl show-session "$session" --property=Active     --value 2>/dev/null)
    locked=$(loginctl show-session "$session" --property=LockedHint --value 2>/dev/null)
    [ "$active" = "yes" ] && [ "$locked" = "no" ] && return 0
    sleep 2
  done
}

wait_for_unlock
VPN_HOSTNAME=$(sed -rn 's/^[[:space:]]*remote[[:space:]]+([^[:space:]]+)[[:space:]]+[[:digit:]]+([[:space:]].*)?$/\1/p' "$VPN_CONF" | head -n1)
VPN_PORT=$(sed -rn 's/^[[:space:]]*remote[[:space:]]+[^[:space:]]+[[:space:]]+([[:digit:]]+)([[:space:]].*)?$/\1/p' "$VPN_CONF" | head -n1)
VPN_MGMT_SOCKET="/run/openvpn-client/$VPN_INSTANCE/mgmt.sock"

tcp_listen()   { socat - "TCP-LISTEN:$1,reuseaddr"; }
unix_connect() { socat - "UNIX-CONNECT:$1"; }
export -f tcp_listen unix_connect

resolve_host() {
  local host="$1"
  local cmd

  if cmd=$(command -v dig 2>/dev/null); then
    "$cmd" a +short "$host" | sed -r '/[^[:digit:].]+/d' | head -n 1
    return $?
  elif cmd=$(command -v host 2>/dev/null); then
    "$cmd" "$host" | sed -rn '{0,/has address/ s/.*has address ([[:digit:].]+)/\1/p;}'
    return $?
  elif cmd=$(command -v nslookup 2>/dev/null); then
    "$cmd" "$host" | sed -rn '{0,/Address: / s/Address: //p}'
    return $?
  elif cmd=$(command -v getent 2>/dev/null); then
    "$cmd" hosts "$host" | awk '{print $1; exit}'
    return $?
  else
    return 1
  fi
}

auth() {
  local addr="$1"
  local port="$2"
  local conf="$3"
  local timeout="${4:-30}"

  local local_port=35001

  local probe_out
  probe_out=$("$VPN_CMD" --remote "$addr" "$port" \
    --config "$conf" \
    --auth-retry none \
    --auth-user-pass <( printf "%s\n%s\n" "N/A" "ACS::$local_port" ) \
    2>&1)
  local out
  out=$(echo "$probe_out" | grep "AUTH_FAILED,CRV1")

  if [[ -z "$out" ]]; then
    echo "ERROR: No SAML challenge received from VPN server. Check system unit logs." >&2
    return 1
  fi

  # get SID from the reply
  local sid
  sid=$(echo "$out" | sed -rn 's/.*AUTH_FAILED,CRV1:R:([^:]+):.*/\1/p')

  local saml_url
  saml_url=$(echo "$out" | grep -Eo 'https://[^[:space:]]+')
  if [[ -z "$saml_url" || -z "$sid" ]]; then
    echo "ERROR: Could not parse SAML challenge response: $out" >&2
    return 1
  fi

  # start a "web server" that will receive the saml response from the idp
  # shellcheck disable=SC2016
  exec 3< <({ printf 'HTTP/1.1 200 OK\r\nContent-Type: text/html; charset=utf-8\r\nConnection: close\r\nCache-Control: no-store\r\n\r\n'; cat "$HTML_BODY"; } | timeout "$timeout" bash -c 'tcp_listen "$1"' -- "$local_port")
  local pid=$!

  # create a trap that will close the "web server" process as well if this script is aborted by CTRL+C
  trap 'kill "$pid" 2>/dev/null' EXIT

  "$BROWSER_CMD" "$saml_url" >/dev/null 2>&1 &

  local response
  response=$(cat <&3)

  wait $pid

  # cleanup the trap
  trap - EXIT

  # if no response was received within the timeout window - exit
  if [[ $(echo "$response" | awk '/SAMLResponse.*$/' | wc -l) -lt 1 ]]; then
    echo "ERROR: No SAML response was received from the IDP." >&2
    exit 1
  fi

  printf "CRV1::%s::%s\n" "$sid" "$(echo -n "$(echo "$response" \
    | awk '/^SAMLResponse=/ { gsub(/SAMLResponse=/,""); gsub(/GET.*$/,""); printf "%s",$0; }')")"

  return 0
}

if [ ! -S "$VPN_MGMT_SOCKET" ]; then
  systemd-notify "STATUS=Waiting for OpenVPN management socket..."
  _waited=0
  until [ -S "$VPN_MGMT_SOCKET" ]; do
    _waited=$((_waited + 1))
    if [ "$_waited" -ge 30 ]; then
      printf "ERROR: No OpenVPN client service is running for %s.\nStart one with:\n  $ systemctl start aws-vpn@%s.service\n" "$VPN_INSTANCE" "$VPN_INSTANCE" >&2
      exit 1
    fi
    sleep 1
  done
fi

VPN_GROUP=$(stat -c '%G' "$VPN_MGMT_SOCKET")

if ! id -Gn | tr ' ' '\n' | grep -Fxq "$VPN_GROUP"; then
  echo "ERROR: User $USER is not in the '$VPN_GROUP' group." >&2
  exit 1
fi

if [ -z "$VPN_PORT" ]; then
  echo "ERROR: No 'remote' parameter found in VPN config file: $VPN_CONF" >&2
  exit 1
fi

VPN_SRV=""
VPN_CONNECTED=0

# connect to OpenVPN client management socket
coproc setsid -w sg "$VPN_GROUP" "bash -c 'unix_connect \"\$1\"' -- '$VPN_MGMT_SOCKET'"
NC_OUT=${COPROC[0]}
NC_IN=${COPROC[1]}
MGMT_PID=${COPROC_PID}

cleanup() {
  # If the tunnel was never established (auth failure, pre-connect crash),
  # signal OpenVPN to do a full reset so the next user unit invocation
  # connects to clean state with no stale cached remote address.
  if [[ "$VPN_CONNECTED" != "1" ]]; then
    echo 'signal SIGHUP' 1>&"$NC_IN" 2>/dev/null
  fi
  kill -- -"$MGMT_PID" 2>/dev/null
  wait "$MGMT_PID" 2>/dev/null
}

disconnect_vpn() {
  # Intentional stop only: TERM is sent by systemd on stop / restart /
  # logout, but never on crashes, OOM, or Restart=on-failure re-entry.
  # Tell OpenVPN to drop the tunnel and re-enter --management-hold so
  # the system unit stays running, ready for the next user unit.
  echo 'signal SIGHUP' 1>&"$NC_IN" 2>/dev/null
  exit 0
}

trap cleanup EXIT
trap disconnect_vpn TERM

echo "state on" >&"$NC_IN"
echo "state" >&"$NC_IN"

while IFS=: read -u "$NC_OUT" -r signal data
do
  case $signal in
    ">HOLD")
      echo "hold release" >&"$NC_IN"
      ;;
    ">REMOTE")
      if [[ "$data" == "$VPN_HOSTNAME,$VPN_PORT,udp"* ]]; then
        if [[ -z "$VPN_SRV" ]]; then
          VPN_SRV=$(resolve_host "$VPN_HOSTNAME")
        fi
        if [[ -z "$VPN_SRV" ]]; then
          echo "WARN: Failed to resolve $VPN_HOSTNAME, skipping." >&2
          echo "remote SKIP" >&"$NC_IN"
          continue
        fi
        echo "remote MOD $VPN_SRV $VPN_PORT" >&"$NC_IN"
      else
        echo "WARN: Skipping attempt to connect to unrecognised endpoint: $data" >&2
        echo "remote SKIP" >&"$NC_IN"
      fi
      ;;
    ">PASSWORD")
      if [[ "$data" == "Need 'Auth' username/password"* ]]; then
        # >PASSWORD can arrive before >REMOTE when OpenVPN pre-fetches
        # credentials. Resolve now so the probe and remote MOD target the
        # same AZ (>REMOTE will reuse VPN_SRV if already set).
        if [[ -z "$VPN_SRV" ]]; then
          VPN_SRV=$(resolve_host "$VPN_HOSTNAME")
        fi
        echo "Opening browser and waiting for the SAML response..."
        if pass=$(auth "$VPN_SRV" "$VPN_PORT" "$VPN_CONF" "$SAML_RESPONSE_TIMEOUT"); then
          echo "username \"Auth\" \"N/A\"" >&"$NC_IN"
          echo "password \"Auth\" \"$pass\"" >&"$NC_IN"
        fi
      else
        echo "ERROR: Unable to supply requested authentication: $data" >&2
        exit 1
      fi
      ;;
    ">STATE")
      state=$(echo "$data" | awk -F, '{ print $2 }')
      case $state in
        CONNECTING)
          echo "Connecting to VPN at $VPN_HOSTNAME ($VPN_SRV)"
          systemd-notify "STATUS=Connecting to VPN at $VPN_HOSTNAME ($VPN_SRV)"
          ;;
        WAIT)
          echo "Waiting for response from $VPN_HOSTNAME ($VPN_SRV)..."
          systemd-notify "STATUS=Waiting for response from $VPN_HOSTNAME ($VPN_SRV)..."
          ;;
        AUTH)
          echo "Authenticating with VPN server..."
          systemd-notify "STATUS=Authenticating with VPN server..."
          ;;
        GET_CONFIG)
          echo "Downloading configuration from VPN server..."
          systemd-notify "STATUS=Downloading configuration from VPN server..."
          ;;
        ASSIGN_IP)
          echo "Assigning IP address to VPN interface..."
          systemd-notify "STATUS=Assigning IP address to VPN interface..."
          ;;
        ADD_ROUTES)
          echo "Adding VPN routes to local system..."
          systemd-notify "STATUS=Adding VPN routes to local system..."
          ;;
        CONNECTED)
          VPN_CONNECTED=1
          _connected_ip=$(printf '%s\n' "$data" | awk -F, '{ print $5 }')
          [[ -n "$_connected_ip" ]] && VPN_SRV="$_connected_ip"
          echo "Connected to VPN at $VPN_HOSTNAME ($VPN_SRV)"
          systemd-notify --ready "STATUS=Connected to VPN at $VPN_HOSTNAME ($VPN_SRV)"
          ;;
        RECONNECTING)
          echo "Reconnecting to VPN at $VPN_HOSTNAME ($VPN_SRV)"
          systemd-notify "STATUS=Reconnecting to VPN at $VPN_HOSTNAME ($VPN_SRV)"
          ;;
        EXITING)
          echo "OpenVPN client shutting down..."
          systemd-notify "STOPPING=1" "STATUS=OpenVPN client shutting down..."
          trap - EXIT TERM
          kill -- -"$MGMT_PID" 2>/dev/null
          wait "$MGMT_PID" 2>/dev/null
          exit 1
          ;;
      esac
      ;;
    "ERROR")
      echo "ERROR: $data" >&2
      ;;
    "FATAL")
      echo "FATAL ERROR: $data" >&2
      break;
      ;;
    "SUCCESS"|"END")
      ;;
    *)
      # Synchronous reply line from the initial 'state' command (no '>' prefix,
      # no ':' so IFS=: puts the whole CSV in $signal). Capture remote IP so
      # VPN_SRV is populated even when the user unit restarts against an
      # already-connected OpenVPN that will not replay >REMOTE. Also send
      # READY=1 when already connected so systemd doesn't wait indefinitely for
      # a >STATE:CONNECTED event that will never arrive.
      if [[ "$signal" =~ ^[0-9] ]]; then
        _ip=$(printf '%s\n' "$signal" | awk -F, '$2=="CONNECTED" && $5!="" { print $5 }')
        if [[ -n "$_ip" ]]; then
          VPN_SRV="$_ip"
          VPN_CONNECTED=1
          systemd-notify --ready "STATUS=Connected to VPN at $VPN_HOSTNAME ($VPN_SRV)"
        fi
      fi
      ;;
  esac
done

systemd-notify "STOPPING=1"
trap - EXIT TERM
kill -- -"$MGMT_PID" 2>/dev/null
